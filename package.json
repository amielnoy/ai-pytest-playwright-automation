{
  "name": "ai-automation-testing",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "pytest tests/",
    "test:smoke": "pytest tests/ -m smoke",
    "test:web": "pytest tests/web-ui/",
    "test:api": "pytest tests/api/",
    "test:unit": "pytest tests/unit/",
    "test:report": "./scripts/run_tests_with_allure.sh",
    "test:all:report": "./scripts/run_all_tests_with_allure.sh",
    "test:docker:report": "./scripts/run_docker_tests_with_allure.sh",
    "test:compose:report": "./scripts/run_compose_tests_with_allure.sh",
    "test:docker": "./scripts/compose_test_report.sh",
    "test:docker:ci": "OPEN_ALLURE=false ./scripts/compose_test_report.sh",
    "test:docker:down": "COMPOSE_DOWN=true OPEN_ALLURE=false ./scripts/compose_test_report.sh",
    "allure:version": "allure --version",
    "allure:generate": "rm -rf allure-report && allure generate ./allure-results -o ./allure-report",
    "allure:open": "allure open allure-report",
    "allure:watch": "allure watch allure-results"
  },
  "devDependencies": {
    "allure": "^3.6.2"
  }
}
