rice}\" for p in products),\n            name=\"Products to add\",\n            attachment_type=allure.attachment_type.TEXT,\n        )\n    \n>       assert products, (\n            f\"No products found for query='{query}' under ${max_price}. \"\n            \"Cannot add to cart.\"\n        )\nE       AssertionError: No products found for query='MacBook' under $700.0. Cannot add to cart.\nE       assert []\n\ntests/web-ui/test_add_to_cart.py:32: AssertionError","start":1778581757149,"stop":1778581758114,"duration":965,"labels":[{"name":"severity","value":"critical"},{"name":"feature","value":"Cart"},{"name":"story","value":"addItemsToCart"},{"name":"tag","value":"cart"},{"name":"parentSuite","value":"tests.web-ui"},{"name":"suite","value":"test_add_to_cart"},{"name":"subSuite","value":"TestAddItemsToCart"},{"name":"host","value":"runnervmeorf1"},{"name":"thread","value":"3031-MainThread"},{"name":"framework","value":"pytest"},{"name":"language","value":"cpython3"},{"name":"package","value":"tests.web-ui.test_add_to_cart"}],"url":"","historyId":"710283ec84005bbc13bb76ff67ccb2e4.d41d8cd98f00b204e9800998ecf8427e","reportLinks":[]},{"id":"4ef66817ce54f268c454585864e4581f","name":"Add items under max_price to cart","fullName":"tests.web-ui.test_add_to_cart.TestAddItemsToCart#test_add_items_to_cart","environment":"default","status":"passed","start":1778581355904,"stop":1778581358581,"duration":2677,"labels":[{"name":"severity","value":"critical"},{"name":"feature","value":"Cart"},{"name":"story","value":"addItemsToCart"},{"name":"tag","value":"cart"},{"name":"parentSuite","value":"tests.web-ui"},{"name":"suite","value":"test_add_to_cart"},{"name":"subSuite","value":"TestAddItemsToCart"},{"name":"host","value":"runnervmeorf1"},{"name":"thread","value":"3052-MainThread"},{"name":"framework","value":"pytest"},{"name":"language","value":"cpython3"},{"name":"package","value":"tests.web-ui.test_add_to_cart"}],"url":"","historyId":"710283ec84005bbc13bb76ff67ccb2e4.d41d8cd98f00b