quisite assert catches that case explicitly.\n        \"\"\"\n        with allure.step(\"Fetch MacBook products (hard assert: must have results)\"):\n>           products = search_results_page.get_products_under_price(\n                query=\"MacBook\", max_price=9999.0, limit=10\n            )\n\ntests/web-ui/test_soft_assertions_demo.py:124: \n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \npages/search_results_page.py:81: in get_products_under_price\n    self._load_search(query)\npages/search_results_page.py:158: in _load_search\n    self._wait_for_search_outcome()\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \n\nself = <pages.search_results_page.SearchResultsPage object at 0x7fd0d1da39b0>\ntimeout = None\n\n    def _wait_for_search_outcome(self, timeout: int | None = None) -> None:\n        \"\"\"Wait until the search page shows either no-results text or product cards.\"\"\"\n        # Use the strict product-thumb selector here — not self-healing fallbacks,\n        # which can match unrelated layout nodes and cause false positives on empty search.\n        outcome = self.no_results_message.or_(\n            self.page.locator(self._PRODUCT_THUMBS).first\n        )\n        if timeout is None:\n>           expect(outcome).to_be_visible()\nE           AssertionError: Locator expected to be visible\nE           Actual value: - img \"Loader\"\nE           - text: Please wait while your request is being verified...\nE           Error: element(s) not found \nE           Call log:\nE             - Expect \"to_be_visible\" with timeout 5000ms\nE             - waiting for get_by_text(\"There is no product that matches the search criteria.\").or_(locator(\".product-thumb\").first)\n\npages/search_results_page.py:168: AssertionError"},"testCase":{"id":"d3c7ee978a051e77d0c82b34753937f3","name":"[SOFT] Search result prices — every failing product reported","fullName":"tests.web-ui.test_soft_assertions_dem