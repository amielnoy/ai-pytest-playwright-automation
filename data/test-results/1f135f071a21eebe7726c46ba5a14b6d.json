 object at 0x7f668d3d19d0>\ncart_flow_pages = CartFlowPages(search_results=<pages.search_results_page.SearchResultsPage object at 0x7f668d3eee40>, cart=<pages.cart_page.CartPage object at 0x7f668d3ff6e0>)\n\n    @allure.title(\"Add items under max_price to cart\")\n    @allure.severity(allure.severity_level.CRITICAL)\n    def test_add_items_to_cart(self, cart_flow_pages: CartFlowPages):\n        search_data = get_test_data(\"search\")\n        query = search_data[\"query\"]\n        max_price = search_data[\"max_price\"]\n        limit = search_data[\"limit\"]\n    \n        with allure.step(f\"Find products matching '{query}' under ${max_price}\"):\n            products = cart_flow_pages.search_results.get_products_under_price(\n                query=query, max_price=max_price, limit=limit\n            )\n    \n        allure.attach(\n            \"\\n\".join(f\"{p.name} — ${p.price}\" for p in products),\n            name=\"Products to add\",\n            attachment_type=allure.attachment_type.TEXT,\n        )\n    \n>       assert products, (\n            f\"No products found for query='{query}' under ${max_price}. \"\n            \"Cannot add to cart.\"\n        )\nE       AssertionError: No products found for query='MacBook' under $700.0. Cannot add to cart.\nE       assert []\n\ntests/web-ui/test_add_to_cart.py:32: AssertionError","start":1778581757149,"stop":1778581758114,"duration":965,"labels":[{"name":"severity","value":"critical"},{"name":"feature","value":"Cart"},{"name":"story","value":"addItemsToCart"},{"name":"tag","value":"cart"},{"name":"parentSuite","value":"tests.web-ui"},{"name":"suite","value":"test_add_to_cart"},{"name":"subSuite","value":"TestAddItemsToCart"},{"name":"host","value":"runnervmeorf1"},{"name":"thread","value":"3031-MainThread"},{"name":"framework","value":"pytest"},{"name":"language","value":"cpython3"},{"name":"package","value":"tests.web-ui.test_add_to_cart"}],"url":"","historyId":"710283ec84005bbc13bb76ff67ccb2e4.d41d8cd98f00b