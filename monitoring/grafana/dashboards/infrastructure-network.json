{
  "title": "Infrastructure & Network",
  "uid": "infra-network",
  "description": "Container resources, network I/O, HTTP API performance, and host metrics",
  "editable": true,
  "refresh": "10s",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "tags": ["infrastructure", "network", "containers"],
  "panels": [

    { "id": 200, "type": "row", "title": "🌐 Network I/O", "collapsed": false,
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 } },

    {
      "id": 201, "type": "timeseries",
      "title": "Network Receive Rate (bytes/s)",
      "description": "Bytes received per second per container",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 2 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "rate(container_network_receive_bytes_total{container_label_com_docker_compose_service!=\"\"}[1m])",
        "legendFormat": "{{container_label_com_docker_compose_service}} rx",
        "refId": "A"
      }]
    },

    {
      "id": 202, "type": "timeseries",
      "title": "Network Transmit Rate (bytes/s)",
      "description": "Bytes transmitted per second per container",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 2 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service!=\"\"}[1m])",
        "legendFormat": "{{container_label_com_docker_compose_service}} tx",
        "refId": "A"
      }]
    },

    {
      "id": 203, "type": "timeseries",
      "title": "Network Receive Errors (packets/s)",
      "description": "Packets dropped or errored on receive per container",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "rate(container_network_receive_errors_total{container_label_com_docker_compose_service!=\"\"}[1m])",
          "legendFormat": "{{container_label_com_docker_compose_service}} rx-err",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_receive_packets_dropped_total{container_label_com_docker_compose_service!=\"\"}[1m])",
          "legendFormat": "{{container_label_com_docker_compose_service}} rx-drop",
          "refId": "B"
        }
      ]
    },

    {
      "id": 204, "type": "timeseries",
      "title": "Network Transmit Errors (packets/s)",
      "description": "Packets dropped or errored on transmit per container",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "rate(container_network_transmit_errors_total{container_label_com_docker_compose_service!=\"\"}[1m])",
          "legendFormat": "{{container_label_com_docker_compose_service}} tx-err",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_transmit_packets_dropped_total{container_label_com_docker_compose_service!=\"\"}[1m])",
          "legendFormat": "{{container_label_com_docker_compose_service}} tx-drop",
          "refId": "B"
        }
      ]
    },

    { "id": 210, "type": "row", "title": "🖥️ Container Resources", "collapsed": false,
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 18 } },

    {
      "id": 211, "type": "timeseries",
      "title": "CPU Usage per Container (%)",
      "description": "CPU utilisation rate per container",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=\"\"}[1m])",
        "legendFormat": "{{container_label_com_docker_compose_service}}",
        "refId": "A"
      }]
    },

    {
      "id": 212, "type": "timeseries",
      "title": "Memory Usage per Container",
      "description": "Working set memory per container",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "container_memory_working_set_bytes{container_label_com_docker_compose_service!=\"\"}",
        "legendFormat": "{{container_label_com_docker_compose_service}}",
        "refId": "A"
      }]
    },

    {
      "id": 213, "type": "table",
      "title": "Container Restart Count",
      "description": "Total restarts per container since stack start",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "container_label_com_docker_compose_service" },
            "properties": [{ "id": "displayName", "value": "Service" }] },
          { "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Restarts" },
              { "id": "custom.width", "value": 120 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 3 }
              ]}},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "desc": true, "displayName": "Restarts" }] },
      "targets": [{
        "expr": "container_start_time_seconds{container_label_com_docker_compose_service!=\"\"} > 0",
        "instant": true,
        "legendFormat": "{{container_label_com_docker_compose_service}}",
        "refId": "A"
      }],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "filterFieldsByName", "options": {
          "include": { "names": ["container_label_com_docker_compose_service", "Value"] }
        }}
      ]
    },

    { "id": 220, "type": "row", "title": "🔗 HTTP API Performance", "collapsed": false,
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 34 } },

    {
      "id": 221, "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "description": "Requests per second by endpoint (excludes /metrics)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "rate(http_request_duration_seconds_count{handler!=\"/metrics\"}[1m])",
        "legendFormat": "{{method}} {{handler}}",
        "refId": "A"
      }]
    },

    {
      "id": 222, "type": "timeseries",
      "title": "HTTP Error Rate (%)",
      "description": "5xx errors as a percentage of all requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]},
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "expr": "rate(http_request_duration_seconds_count{status=~\"5..\",handler!=\"/metrics\"}[1m]) / rate(http_request_duration_seconds_count{handler!=\"/metrics\"}[1m])",
        "legendFormat": "{{method}} {{handler}}",
        "refId": "A"
      }]
    },

    {
      "id": 223, "type": "timeseries",
      "title": "P50 / P95 / P99 Latency by Endpoint",
      "description": "Response time percentiles (excluding /metrics scrapes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler!=\"/metrics\"}[1m]))",
          "legendFormat": "p50 {{handler}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler!=\"/metrics\"}[1m]))",
          "legendFormat": "p95 {{handler}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler!=\"/metrics\"}[1m]))",
          "legendFormat": "p99 {{handler}}",
          "refId": "C"
        }
      ]
    },

    {
      "id": 224, "type": "piechart",
      "title": "Request Count by Status Code",
      "description": "Distribution of HTTP responses by status class",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "targets": [{
        "expr": "sum by (status) (increase(http_request_duration_seconds_count{handler!=\"/metrics\"}[1h]))",
        "legendFormat": "{{status}}",
        "refId": "A"
      }]
    },

    { "id": 230, "type": "row", "title": "🏠 Host", "collapsed": false,
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 52 } },

    {
      "id": 231, "type": "timeseries",
      "title": "Host CPU Usage (%)",
      "description": "Total CPU utilisation across all cores on the Docker host",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 54 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m]))",
        "legendFormat": "CPU busy",
        "refId": "A"
      }]
    },

    {
      "id": 232, "type": "timeseries",
      "title": "Host Memory",
      "description": "Available and total memory on the Docker host",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "last"] } },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total",
          "refId": "B"
        }
      ]
    },

    {
      "id": 233, "type": "timeseries",
      "title": "Host Disk I/O (bytes/s)",
      "description": "Disk read/write throughput on the Docker host",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 62 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[1m])",
          "legendFormat": "read {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[1m])",
          "legendFormat": "write {{device}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 234, "type": "timeseries",
      "title": "Host Network I/O (bytes/s)",
      "description": "Network throughput on host interfaces",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 62 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\"}[1m])",
          "legendFormat": "rx {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\"}[1m])",
          "legendFormat": "tx {{device}}",
          "refId": "B"
        }
      ]
    }

  ]
}
