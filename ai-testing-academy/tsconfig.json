{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "assets/js",
    "rootDir": "src",
    "sourceMap": false,
    "removeComments": false,
    "newLine": "lf"
  },
  "include": ["src/**/*.ts"]
}
